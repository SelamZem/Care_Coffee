# Copy this file to .env and fill in your actual values

# Django Security
SECRET_KEY=your-super-secret-key-here-at-least-50-characters-long-and-random
DJANGO_DEVELOPMENT=False
DEBUG=False

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///db.sqlite3
# For production: DATABASE_URL=postgresql://user:password@localhost:5432/carecoffee

# Chapa Payment Integration (Get from https://dashboard.chapa.co/)
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxxxxxxxxxx
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-xxxxxxxxxxxxxxxx
CHAPA_CALLBACK_URL=https://your-domain.com/order/chapa/webhook/
CHAPA_RETURN_URL=https://your-domain.com/order/success/{order_id}/
BASE_URL=https://your-domain.com

# Email Configuration (for order confirmations)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Care Coffee <your-email@gmail.com>

# Allowed Hosts (add your production domain)
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,*.onrender.com

# CSRF Trusted Origins (add your production URL)
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://*.onrender.com
